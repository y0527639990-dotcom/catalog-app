# Supabase — פרויקט bait ב-https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# אופציונלי — להרצת schema אוטומטית: ./scripts/run-schema.sh
# SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
# SUPABASE_DB_PASSWORD=your-db-password

# שם האפליקציה
NEXT_PUBLIC_APP_NAME=Bait

# כתובת האפליקציה (לפרסום ב-Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# סיסמה לחתימת sessions (צור עם: openssl rand -hex 32)
SESSION_SECRET=change-me-to-random-string
